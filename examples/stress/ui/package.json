{
  "name": "stress-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:prod": "node build.mjs --prod",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "bevy:generate": "cargo run --manifest-path ../../../crates/core/Cargo.toml --example stress -- --export-bindings src/bevy.ts"
  },
  "dependencies": {
    "bevy-react": "*",
    "react": "18.3.1",
    "react-reconciler": "0.29.2"
  },
  "devDependencies": {
    "@swc/core": "1.10.1",
    "@types/react": "18.3.12",
    "esbuild": "0.24.0",
    "react-refresh": "0.14.2",
    "typescript": "5.6.3"
  }
}

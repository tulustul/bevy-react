{
  "name": "demos-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=esm --platform=neutral --target=es2022 --jsx=automatic --jsx-import-source=bevy-react --define:process.env.NODE_ENV='\"production\"' --outfile=dist/bundle.js",
    "watch": "npm run build -- --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "gen:bindings": "cargo run --manifest-path ../../../Cargo.toml --example demos -- --export-bindings src/generated.ts"
  },
  "dependencies": {
    "bevy-react": "*",
    "react": "18.3.1",
    "react-reconciler": "0.29.2"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "esbuild": "0.24.0",
    "typescript": "5.6.3"
  }
}

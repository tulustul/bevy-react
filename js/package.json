{
  "name": "bevy-react",
  "version": "0.1.0",
  "description": "Drive bevy_ui from React via a custom reconciler over an embedded V8 runtime.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./jsx": "./src/jsx.d.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-dev-runtime.ts",
    "./build-lib": "./build-lib.mjs"
  },
  "files": [
    "src",
    "build-lib.mjs"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-reconciler": "^0.29.2"
  },
  "dependencies": {
    "react-refresh": "^0.14.2"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-reconciler": "0.28.9",
    "typescript": "5.6.3"
  }
}

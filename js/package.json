{
  "name": "bevy-react-js",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=esm --platform=neutral --target=es2022 --define:process.env.NODE_ENV='\"production\"' --outfile=dist/bundle.js",
    "watch": "npm run build -- --watch"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-reconciler": "0.29.2"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-reconciler": "0.28.9",
    "esbuild": "0.24.0",
    "typescript": "5.6.3"
  }
}

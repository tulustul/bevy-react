{
  "name": "bevy-react",
  "version": "0.1.0",
  "description": "Drive bevy_ui from React via a custom reconciler over an embedded V8 runtime.",
  "license": "MIT OR Apache-2.0",
  "author": "Mateusz Tomczyk <mateusz.tomczyk.tul@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tulustul/bevy-react.git"
  },
  "homepage": "https://github.com/tulustul/bevy-react#readme",
  "bugs": {
    "url": "https://github.com/tulustul/bevy-react/issues"
  },
  "type": "module",
  "bin": {
    "bevy-react": "./bin/cli.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./jsx": "./src/jsx.d.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-dev-runtime.ts",
    "./build-lib": "./build-lib.mjs"
  },
  "files": [
    "src",
    "build-lib.mjs",
    "bin",
    "templates"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test test/*.test.mjs"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-reconciler": "^0.33.0"
  },
  "dependencies": {
    "react-refresh": "^0.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-reconciler": "^0.33.0",
    "esbuild": "0.24.0",
    "typescript": "5.6.3"
  }
}

{
  "name": "bevy-react-workspace",
  "private": true,
  "workspaces": [
    "js",
    "examples/demos/ui",
    "examples/stress/ui"
  ],
  "scripts": {
    "lint": "eslint . && npm run typecheck && npm run lint:rust",
    "lint:fix": "eslint . --fix",
    "lint:rust": "cargo clippy --workspace --all-targets",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write . && cargo fmt",
    "format:check": "prettier --check . && cargo fmt --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.20.0"
  }
}
